<Templates:TicketTemplate x:Class="HwModule.View.TicketTemplates.SeatTemp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Templates="clr-namespace:HwModule.View.TicketTemplates"
             xmlns:Converters="clr-namespace:HwModule.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DataContext="{d:DesignInstance Type=Templates:SeatTemp, IsDesignTimeCreatable=True}" Width="278">
    <Templates:TicketTemplate.Resources>
        <Converters:DateFormatConverter x:Key="DateFormatConverter"/>
        <Converters:DateTimeFormatConverter x:Key="DateTimeFormatConverter"/>
        <Converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <Converters:StringToIntConverter x:Key="StringToIntConverter"/>
        <Converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <Converters:ValueMatchToVisibilityConverter x:Key="ValueMatchToVisibilityConverter"/>
    </Templates:TicketTemplate.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <FlowDocumentReader x:Name="DocReader" BorderThickness="1" BorderBrush="DarkGray" RenderTransformOrigin="0.0,0.0">
            <FlowDocument x:Name="Doc"  PagePadding="0,0,0,0" Background="{Binding DataContext.DocBackground, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Paragraph>
                    <Grid x:Name="DocMainGrid" Width="270">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" >
                            <TextBlock Text="{Binding DataContext.DisplayTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="17" FontFamily="Arial" FontWeight="Medium" TextWrapping="WrapWithOverflow" Width="275" TextAlignment="Center" HorizontalAlignment="Center" Height="240" VerticalAlignment="Top"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" >
                            <TextBlock Text="{Binding DataContext.DisplayTicketName, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="17" FontFamily="Arial" FontWeight="Medium" TextWrapping="WrapWithOverflow" Width="275" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" >
                            <TextBlock Text="{Binding DataContext.DisplayMoveCategory, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="17" FontFamily="Arial" FontWeight="Medium" TextWrapping="WrapWithOverflow" Width="275" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Margin="0,10,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,2,0,0" Text="====================================================" FontSize="11"/>
                        </StackPanel>

                        <Grid Grid.Row="4" Margin="-5,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="29"/>
                                <ColumnDefinition Width="89"/>
                                <ColumnDefinition Width="63"/>
                                <ColumnDefinition Width="97"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="5,0,0,0" Text="좌석" TextAlignment="Left" FontSize="13" FontWeight="Light" FontFamily="Arial"/>
                            <TextBlock Grid.Column="1" Margin="0,0,0,0" Text="이름" TextAlignment="Center" FontSize="13" FontWeight="Light" FontFamily="Arial"/>
                            <TextBlock Grid.Column="2" Margin="0,0,0,0" Text="생년월일" TextAlignment="Center" FontSize="13" FontWeight="Light" FontFamily="Arial"/>
                            <TextBlock Grid.Column="3" Margin="0,0,6,0" Text="전화번호" TextAlignment="Right" FontSize="13" FontWeight="Light" FontFamily="Arial"/>
                        </Grid>

                        <StackPanel Grid.Row="5" Margin="-2,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,0,0,0" Text="-----------------------------------------------------------------------------------------------" FontSize="11"/>
                        </StackPanel>

                        <Grid Grid.Row="6" Margin="-2,0,0,0">
                            <ItemsControl ItemsSource="{Binding DataContext.OrderSeatList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="29"/>
                                                <ColumnDefinition Width="89"/>
                                                <ColumnDefinition Width="63"/>
                                                <ColumnDefinition Width="97"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Margin="5,2,0,0" Text="{Binding Path=[seat_no]}" TextAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1" Margin="0,2,0,0" Text="{Binding Path=[name]}" TextAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="2" Margin="0,2,0,5" Text="{Binding Path=[birth], StringFormat={}{0:yyyy.MM.dd}}" TextAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="3" Margin="0,2,6,5" Text="{Binding Path=[phone]}" TextAlignment="Right" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <StackPanel Grid.Row="7" Margin="0,-4,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,0,0,0" Text="-----------------------------------------------------------------------------------------------" FontSize="11"/>
                        </StackPanel>

                        <StackPanel Grid.Row="8" Margin="10,0,0,0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <TextBlock Margin="0,3,0,0" Text="총 인원" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Row="8" Margin="0,0,12,0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Margin="0,3,0,0" Text="{Binding Path=DataContext.DisplayTotalCnt, Converter={StaticResource StringToIntConverter}, FallbackValue='0명', TargetNullValue='0명', StringFormat='{}{0:#,0}명'}" FontSize="14" FontFamily="Arial"/>
                        </StackPanel>

                        <StackPanel Grid.Row="9" Margin="0,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,0,0,0" Text="-----------------------------------------------------------------------------------------------" FontSize="11"/>
                        </StackPanel>

                        <TextBlock Grid.Row="10" Margin="0,10,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">         
                            <Run Text="{Binding DataContext.ReceiptCont, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                </Paragraph>
            </FlowDocument>
        </FlowDocumentReader>
    </Grid>
</Templates:TicketTemplate>