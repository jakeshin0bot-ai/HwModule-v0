<Templates:TicketTemplate x:Class="HwModule.View.TicketTemplates.AddPayTemp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Templates="clr-namespace:HwModule.View.TicketTemplates"
             xmlns:Converters="clr-namespace:HwModule.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DataContext="{d:DesignInstance Type=Templates:AddPayTemp, IsDesignTimeCreatable=True}" Width="278">
    <Templates:TicketTemplate.Resources>
        <Converters:DateFormatConverter x:Key="DateFormatConverter"/>
        <Converters:DateTimeFormatConverter x:Key="DateTimeFormatConverter"/>
        <Converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <Converters:StringToIntConverter x:Key="StringToIntConverter"/>
        <Converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <Converters:StringYesOrNoToVisibilityConverter x:Key="StringYesOrNoToVisibilityConverter"/>
        <Converters:StringOrderStateVisibilityConverter x:Key="StringOrderStateVisibilityConverter"/>
        <Converters:ValueMatchToVisibilityConverter x:Key="ValueMatchToVisibilityConverter"/>
    </Templates:TicketTemplate.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <FlowDocumentReader x:Name="DocReader" BorderThickness="1" BorderBrush="DarkGray" RenderTransformOrigin="0.0,0.0">
            <FlowDocument x:Name="Doc"  PagePadding="0,0,0,0" Background="{Binding DataContext.DocBackground, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Paragraph>
                    <Grid x:Name="DocMainGrid" Width="278">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" >
                            <TextBlock Text="{Binding DataContext.DisplayTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="17" FontWeight="Medium" TextWrapping="WrapWithOverflow" Width="275" TextAlignment="Center" HorizontalAlignment="Center" Height="20" VerticalAlignment="Top"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" >
                            <TextBlock Text="{Binding DataContext.DisplaySubTitle, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="13" FontWeight="Medium" TextWrapping="WrapWithOverflow" Width="275" TextAlignment="Center" HorizontalAlignment="Center" Height="311" VerticalAlignment="Top"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Margin="0,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                            <Run Text="예약번호 :"/>
                            <Run Text="{Binding DataContext.OrderNum, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="3" Margin="0,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                            <Run Text="회차 :"/>
                            <Run Text="{Binding DataContext.TicketName, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="4" Margin="0,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="발권일시 :"/>
                           <Run Text="{Binding DataContext.PrintDate, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </TextBlock>

                        <StackPanel Grid.Row="5" Margin="0,-1,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,2,0,0" Text="====================================================" FontSize="11"/>
                        </StackPanel>

                        <Grid Grid.Row="6" Margin="0,3,0,0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="77"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="63"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="5,0,0,0" Text="추가금액" TextAlignment="Left" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap"/>
                            <TextBlock Grid.Column="3" Margin="0,0,0,-5" Text="{Binding Path=DataContext.PayAmt, Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원'}" TextAlignment="Right" FontSize="14" FontWeight="Light" FontFamily="Arial"/>
                        </Grid>

                        <StackPanel Grid.Row="7" Margin="0,-6,0,0" Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding DataContext.CancAmt, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Canvas.Top="182" Margin="0,3,0,0" Text="-----------------------------------------------------------------------------------------------" FontSize="11"/>
                        </StackPanel>

                        <Grid Grid.Row="8" Margin="0,3,0,0" VerticalAlignment="Center" Visibility="{Binding DataContext.CancAmt, Converter={StaticResource StringToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="77"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="63"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="5,0,0,0" Text="취소금액" TextAlignment="Left" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap"/>
                            <TextBlock Grid.Column="3" Margin="0,0,0,-5" Text="{Binding Path=DataContext.Amt, Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원'}" TextAlignment="Right" FontSize="14" FontWeight="Light" FontFamily="Arial"/>
                        </Grid>

                        <StackPanel Grid.Row="9" Margin="0,-6,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Canvas.Top="182" Margin="0,3,0,0" Text="-----------------------------------------------------------------------------------------------" FontSize="11"/>
                        </StackPanel>

                        <TextBlock Grid.Row="10" Margin="5,1,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="[거래일시]"/>    
                           <Run Text="{Binding DataContext.DisplayAuthDate, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="11" Margin="5,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap" Visibility="{Binding DataContext.AuthCode, Converter={StaticResource StringToVisibilityConverter}}">
                           <Run Text="[승인번호]"/>
                           <Run Text="{Binding DataContext.AuthCode, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="12" Margin="5,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap" Visibility="{Binding DataContext.DisplayCardInfo, Converter={StaticResource StringToVisibilityConverter}}">
                           <Run Text="[결제정보]"/>
                           <Run Text="{Binding DataContext.DisplayCardInfo, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="13" Margin="5,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="[거래금액]"/>            
                           <Run Text="{Binding DataContext.DisplayPayAmt, Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원', RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="14" Margin="5,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap" Visibility="{Binding DataContext.Vat, Converter={StaticResource StringToVisibilityConverter}}">
                           <Run Text="[부가세]"/>            
                           <Run Text="{Binding DataContext.Vat, Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원', RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="15" Margin="5,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap" Visibility="{Binding DataContext.Vat, Converter={StaticResource StringToVisibilityConverter}}">
                           <Run Text="[총합계]"/>            
                           <Run Text="{Binding DataContext.TotalPay, Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원', RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <StackPanel Grid.Row="16" Margin="0,-1,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,3,0,0" Text="====================================================" FontSize="11"/>
                        </StackPanel>

                        <TextBlock Grid.Row="17" Margin="0,1,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="상호 :"/>    
                           <Run Text="{Binding DataContext.FranName, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="18" Margin="0,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="전화번호 :"/>
                           <Run Text="{Binding DataContext.MastTel, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource DateTimeFormatConverter}}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="19" Margin="0,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="사업자번호 :"/>
                           <Run Text="{Binding DataContext.BusiNum, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="20" Margin="0,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="주소 :"/>
                           <Run Text="{Binding DataContext.Address, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="21" Margin="0,3,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="대표자 :"/>
                           <Run Text="{Binding DataContext.MastName, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <StackPanel Grid.Row="22" Margin="0,-2,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,3,0,0" Text="====================================================" FontSize="11"/>
                        </StackPanel>

                        <TextBlock Grid.Row="23" Margin="0,5,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap" Visibility="{Binding DataContext.DisplaySubCheck, Converter={StaticResource StringYesOrNoToVisibilityConverter}}">
                            <Run Text="{Binding DataContext.ReceiptCont, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/> 
                        </TextBlock>
                    </Grid>
                </Paragraph>
            </FlowDocument>
        </FlowDocumentReader>
    </Grid>
</Templates:TicketTemplate>