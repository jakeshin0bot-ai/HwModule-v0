<Templates:TicketTemplate x:Class="HwModule.View.TicketTemplates.TicketV3"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Templates="clr-namespace:HwModule.View.TicketTemplates"
             xmlns:Converters="clr-namespace:HwModule.View.Converters"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="560"
             d:DataContext="{d:DesignInstance Type=Templates:TicketV3, IsDesignTimeCreatable=True}"
             Width="560">
    <!--
        TicketV3 — 가로형(Landscape) 이용권 티켓
        출력 용지: 148mm x 100mm (A6 가로) 기준
        96dpi 기준: 560px x 378px
    -->
    <Templates:TicketTemplate.Resources>
        <Converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Templates:TicketTemplate.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="560"/>
        </Grid.ColumnDefinitions>
        <FlowDocumentReader x:Name="DocReader" BorderThickness="0" RenderTransformOrigin="0,0" ViewingMode="Scroll">
            <FlowDocument x:Name="Doc" PagePadding="0,0,0,0"
                          Background="{Binding DataContext.DocBackground, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Paragraph>
                    <!-- 메인 카드 -->
                    <Grid x:Name="DocMainGrid" Width="540" Margin="{Binding DataContext.DocMargin, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- 외곽 테두리 시작 -->
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="2" CornerRadius="4" Padding="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- QR 영역 -->
                                    <ColumnDefinition Width="120"/>
                                    <!-- 구분선 -->
                                    <ColumnDefinition Width="12"/>
                                    <!-- 정보 영역 -->
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- ── QR 코드 + 예약번호 ── -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Image x:Name="QrImage" Width="110" Height="110"
                                           Source="{Binding DataContext.QrCodeSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Stretch="Uniform"/>
                                    <TextBlock Text="{Binding DataContext.OrderNum, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               FontSize="8.5" FontFamily="Consolas" TextAlignment="Center"
                                               Margin="0,3,0,0" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- ── 세로 구분선 ── -->
                                <Rectangle Grid.Column="1" Width="1" Fill="#CCCCCC"
                                           VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

                                <!-- ── 예약 정보 ── -->
                                <Grid Grid.Column="2" Margin="8,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>  <!-- 헤더 -->
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>  <!-- 구분선 -->
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>  <!-- 정보행들 -->
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>  <!-- 구분선 -->
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>  <!-- 알림 문구 -->
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>  <!-- 발권일시 -->
                                    </Grid.RowDefinitions>

                                    <!-- 헤더: 시설명 + 이용권 -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DataContext.FacilityName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   FontSize="13" FontWeight="Bold" TextWrapping="Wrap"/>
                                        <Border Grid.Column="1" Background="#333333" CornerRadius="3" Padding="6,2" VerticalAlignment="Center">
                                            <TextBlock Text="이 용 권" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>

                                    <!-- 구분선 -->
                                    <Rectangle Grid.Row="2" Height="1" Fill="#DDDDDD"/>

                                    <!-- 예약시설/구역 -->
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="예약시설" FontSize="10" Foreground="#666666"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DataContext.AreaName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   FontSize="10" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- 좌석 목록 -->
                                    <Grid Grid.Row="5" Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="좌석/구역" FontSize="10" Foreground="#666666"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DataContext.RoomListText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   FontSize="10" TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- 이용기간 -->
                                    <Grid Grid.Row="6" Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="이용기간" FontSize="10" Foreground="#666666"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DataContext.UsePeriod, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Grid>

                                    <!-- 예약자명 -->
                                    <Grid Grid.Row="7" Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="예약자명" FontSize="10" Foreground="#666666"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DataContext.GuestName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   FontSize="11" FontWeight="Bold"/>
                                    </Grid>

                                    <!-- 차량번호 (입력 시만 표시) -->
                                    <Grid Grid.Row="8" Margin="0,2,0,0"
                                          Visibility="{Binding DataContext.CarNum, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StringToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="차량번호" FontSize="10" Foreground="#666666"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DataContext.CarNum, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Grid>

                                    <!-- 구분선 -->
                                    <Rectangle Grid.Row="9" Height="1" Fill="#DDDDDD" Margin="0,4,0,0"/>

                                    <!-- 한줄 알림 -->
                                    <TextBlock Grid.Row="11"
                                               Text="{Binding DataContext.TicketFooter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               FontSize="9" Foreground="#555555" TextWrapping="Wrap"
                                               Visibility="{Binding DataContext.TicketFooter, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StringToVisibilityConverter}}"/>

                                    <!-- 발권일시 (작게) -->
                                    <TextBlock Grid.Row="13"
                                               FontSize="8" Foreground="#AAAAAA" TextAlignment="Right">
                                        <Run Text="발권: "/>
                                        <Run Text="{Binding DataContext.PrintedAtText, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    </TextBlock>

                                </Grid>
                            </Grid>
                        </Border>

                    </Grid>
                </Paragraph>
            </FlowDocument>
        </FlowDocumentReader>
    </Grid>
</Templates:TicketTemplate>
