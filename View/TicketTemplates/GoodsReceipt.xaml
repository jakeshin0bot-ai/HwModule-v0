<Templates:TicketTemplate x:Class="HwModule.View.TicketTemplates.GoodsReceipt"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Templates="clr-namespace:HwModule.View.TicketTemplates"
             xmlns:Converters="clr-namespace:HwModule.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DataContext="{d:DesignInstance Type=Templates:GoodsReceipt, IsDesignTimeCreatable=True}" Width="280">
    <Templates:TicketTemplate.Resources>
        <Converters:DateFormatConverter x:Key="DateFormatConverter"/>
        <Converters:DateTimeFormatConverter x:Key="DateTimeFormatConverter"/>
        <Converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <Converters:StringToIntConverter x:Key="StringToIntConverter"/>
        <Converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <Converters:ValueMatchToVisibilityConverter x:Key="ValueMatchToVisibilityConverter"/>
    </Templates:TicketTemplate.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <FlowDocumentReader x:Name="DocReader" BorderThickness="1" BorderBrush="DarkGray" RenderTransformOrigin="0.0,0.0" ViewingMode="Scroll">
            <FlowDocument x:Name="Doc" PagePadding="0,0,0,0" Background="{Binding DataContext.DocBackground, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Paragraph>
                    <Grid x:Name="DocMainGrid" Width="280">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="15"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                            <RowDefinition Height="AUTO"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" >
                            <TextBlock Text="{Binding DataContext.CampName, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="17" FontWeight="Medium" TextWrapping="WrapWithOverflow" Width="300" TextAlignment="Left" HorizontalAlignment="Center" Height="311" VerticalAlignment="Top"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                            <Run Text="사업자번호 : "/>
                            <Run Text="{Binding DataContext.BusiNo, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="2" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                            <Run Text="대표자명 : "/>
                            <Run Text="{Binding DataContext.MasterName, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="3" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                            <Run Text="주소 : "/>
                            <Run Text="{Binding DataContext.Address, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="4" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="TEL : "/>
                           <Run Text="{Binding DataContext.Tel, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </TextBlock>

                        <StackPanel Grid.Row="5" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,3,0,0" Text="--------------------------------------------------"/>
                        </StackPanel>

                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="5,0,0,0" Text="상품명" TextAlignment="Left" FontSize="12" FontWeight="Light" FontFamily="Arial"/>
                            <TextBlock Grid.Column="1" Margin="0,0,0,0" Text="수량" TextAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial"/>
                            <TextBlock Grid.Column="2" Margin="0,0,0,-5" Text="금액" TextAlignment="Right" FontSize="12" FontWeight="Light" FontFamily="Arial"/>
                        </Grid>

                        <StackPanel Grid.Row="7" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,-10,0,0" Text="--------------------------------------------------"/>
                        </StackPanel>

                        <Grid Grid.Row="8" Margin="0,-3,0,0">
                            <ItemsControl ItemsSource="{Binding DataContext.GoodsOrderDetailList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Margin="5,0,0,0" Text="{Binding Path=[GOODS_NAME]}" TextAlignment="Left" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1" Margin="0,0,0,0" Text="{Binding Path=[TOTAL_CNT], Converter={StaticResource StringToIntConverter}, StringFormat='{}{0:#,0}개'}" TextAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial"/>
                                            <TextBlock Grid.Column="2" Margin="0,0,0,-5" Text="{Binding Path=[TOTAL_PAY], Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원'}" TextAlignment="Right" FontSize="12" FontWeight="Light" FontFamily="Arial"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <StackPanel Grid.Row="9" Margin="0,-8,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Canvas.Top="182" Margin="0,0,0,0" Text="--------------------------------------------------"/>
                        </StackPanel>

                        <TextBlock Grid.Row="10" Margin="0,-2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="거래일시 : "/>
                           <Run Text="{Binding DataContext.AuthDate, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource DateTimeFormatConverter}}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="11" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="승인번호 : "/>
                           <Run Text="{Binding DataContext.AuthCode, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="12" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap" Visibility="{Binding DataContext.PayMethod, Converter={StaticResource ValueMatchToVisibilityConverter}, ConverterParameter='CARD'}">
                           <Run Text="카드번호 : "/>
                           <Run Text="{Binding DataContext.DisplayCardInfo, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="12" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap" Visibility="{Binding DataContext.PayMethod, Converter={StaticResource ValueMatchToVisibilityConverter}, ConverterParameter='CASH'}">
                           <Run Text="결제방법 : "/>            
                           <Run Text="{Binding DataContext.DisplayCardInfo, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="13" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="이용금액 : "/>
                           <Run Text="{Binding DataContext.DisplayTotalAmt, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay,  Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원'}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="14" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap" Visibility="{Binding DataContext.Vat, Converter={StaticResource StringToVisibilityConverter}}">
                           <Run Text="부가세 : "/>
                           <Run Text="{Binding DataContext.Vat, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원'}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="15" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap">
                           <Run Text="총 결제금액 : "/>
                           <Run Text="{Binding DataContext.TotalPay, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay, Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원'}"/>
                        </TextBlock>

                        <TextBlock Grid.Row="16" Margin="0,2,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="Light" FontFamily="Arial" TextWrapping="Wrap" Visibility="{Binding DataContext.OrderStatus, Converter={StaticResource ValueMatchToVisibilityConverter}, ConverterParameter='1'}">
                           <Run Text="취소금액 : "/>              
                           <Run Text="{Binding DataContext.TotalPay, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay, Converter={StaticResource StringToIntConverter}, FallbackValue='0원', TargetNullValue='0원', StringFormat='{}{0:#,0}원'}"/>
                        </TextBlock>
                    </Grid>
                </Paragraph>
            </FlowDocument>
        </FlowDocumentReader>
    </Grid>
</Templates:TicketTemplate>