<Application x:Class="HwModule.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Converters="clr-namespace:HwModule.View.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Converters:BoolToVisibilityConverter x:Key="HideBoolToVisibilityConverter" Collapse="False"/>
        <Converters:BoolToVisibilityConverter x:Key="CollapseBoolToVisibilityConverter" Collapse="True"/>
        <Converters:BoolToVisibilityConverter x:Key="ReverseBoolToVisibilityConverter" Reverse="True" Collapse="True"/>
    </Application.Resources>
</Application>